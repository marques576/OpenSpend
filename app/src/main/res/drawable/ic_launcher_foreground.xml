<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Pie chart icon representing spending/expenses
        White rounded square background with gradient pie chart segments
    -->

    <!-- Main icon centered at 54,54 with size ~66x66 dp (within safe zone) -->
    <group
        android:translateX="21"
        android:translateY="21">

        <!-- Background: white rounded square -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M10,0 L56,0 Q66,0 66,10 L66,56 Q66,66 56,66 L10,66 Q0,66 0,56 L0,10 Q0,0 10,0 Z" />

        <!-- Top-right quarter: light gray -->
        <path
            android:fillColor="#E0E0E0"
            android:pathData="M33,33 L33,6
                A27,27 0 0,1 60,33
                L33,33 Z" />

        <!-- Bottom-left three-quarters: gradient from mint green to lavender -->
        <path
            android:pathData="M33,33 L60,33
                A27,27 0 1,1 33,6
                L33,33 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="15"
                    android:startY="15"
                    android:endX="55"
                    android:endY="55"
                    android:type="linear">
                    <item
                        android:offset="0.0"
                        android:color="#FFA7F3D0" />
                    <item
                        android:offset="0.5"
                        android:color="#FFB8C5E8" />
                    <item
                        android:offset="1.0"
                        android:color="#FFC4B5FD" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Small gap/separator between segments -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M33,31 L35,31 L35,33 L31,33 L31,35 L33,35 L33,31 Z" />

    </group>

</vector>
